#env
.env
.env.*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Electron build output — generated by electron-builder, never committed
release/

# Source data for content-generation scripts in scripts/ — large, derived
# from upstream projects (MITRE ATT&CK JSON, atomic-red-team, hacktricks)
# and re-fetched on demand. Not needed by the app at runtime.
generated/

# Offline content-generation scripts (MITRE ATT&CK → .library, etc.).
# Tooling rather than app source; excluded from the repo.
scripts/

# Pre-built .library packs (MITRE ATT&CK, cert study, etc.) — produced by
# scripts in scripts/ and imported into the app from disk. Personal content
# rather than app source; excluded from the repo.
library-packs/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# Local tool artifacts — not part of the project
.claude/
.codex
# Local shell helper that resumes a specific Claude session — machine-specific.
claude
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env